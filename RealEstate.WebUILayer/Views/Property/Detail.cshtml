@using RealEstate.WebUILayer.DTOs.ProductDetailDTOs
@model RealEstate.WebUILayer.DTOs.ProductDTOs.ResultProductDTO
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var detail = ViewBag.Detail as ResultProductDetailDTO;
}

@await Component.InvokeAsync("_PageHeroComponentPartial", new { title = "İlan Detayı", breadcrumbCurrent = Model.ProductTitle })

<section class="ftco-section ftco-property-details">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-12">
                <div class="property-details">
                    <div class="img" style="background-image: url('@Model.ProductCoverImage'); min-height: 400px; background-size: cover; background-position: center;"></div>
                    <div class="text text-center py-4">
                        <span class="subheading">@Model.ProductCity - @Model.ProductDistrict</span>
                        <h2>@Model.ProductTitle</h2>
                        <p class="price text-primary font-weight-bold" style="font-size: 1.5rem;">₺@Model.ProductPrice.ToString("N2")</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="p-4 bg-light rounded">
                    <h3 class="mb-3">Açıklama</h3>
                    <p>@Model.ProductDescription</p>
                    <p class="mb-0"><strong>Adres:</strong> @Model.ProductAddress</p>
                </div>
            </div>
        </div>
        @if (detail != null && detail.ProductDetailId != 0)
        {
            <div class="row mt-4">
                <div class="col-md-12">
                    <h3 class="mb-3">Özellikler</h3>
                    <div class="row">
                        <div class="col-md-4"><strong>m²:</strong> @detail.ProductSize</div>
                        <div class="col-md-4"><strong>Yatak odası:</strong> @detail.ProductBedRoomCount</div>
                        <div class="col-md-4"><strong>Banyo:</strong> @detail.ProductBathCount</div>
                        <div class="col-md-4"><strong>Oda:</strong> @detail.ProductRoomCount</div>
                        <div class="col-md-4"><strong>Garaj:</strong> @detail.ProductGarageSize</div>
                        <div class="col-md-4"><strong>Yapım yılı:</strong> @detail.ProductBuildYear</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(detail.ProductLocation))
                    {
                        <div class="mt-4">
                            <h4 class="mb-2">Konum</h4>
                            <div class="embed-responsive embed-responsive-16by9">
                                @Html.Raw(detail.ProductLocation)
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        <div class="row mt-4">
            <div class="col-12 text-center">
                <a asp-action="Index" class="btn btn-primary">Tüm ilanlara dön</a>
            </div>
        </div>
    </div>
</section>
