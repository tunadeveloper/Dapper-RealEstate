@model RealEstate.WebUILayer.Models.PageHeroViewModel

<section class="hero-wrap hero-wrap-2 ftco-degree-bg js-fullheight" style="background-image: url('/uptown/images/bg_1.jpg');" data-stellar-background-ratio="0.5">
    <div class="overlay"></div>
    <div class="container">
        <div class="row no-gutters slider-text js-fullheight align-items-center justify-content-center">
            <div class="col-md-9 ftco-animate pb-5 text-center">
                <p class="breadcrumbs">
                    <span class="mr-2"><a asp-controller="Home" asp-action="Index">Ana Sayfa <i class="ion-ios-arrow-forward"></i></a></span>
                    <span>@Model.BreadcrumbCurrent <i class="ion-ios-arrow-forward"></i></span>
                </p>
                <h1 class="mb-3 bread">@Model.Title</h1>
            </div>
        </div>
    </div>
</section>
