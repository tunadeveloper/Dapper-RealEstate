@using RealEstate.WebUILayer.DTOs.EmployeeDTOs
@model List<ResultEmployeeDTO>
<section class="ftco-section ftco-agent ftco-no-pt">
    <div class="container">
        <div class="row justify-content-center pb-5">
            <div class="col-md-12 heading-section text-center ftco-animate">
                <span class="subheading">Danışmanlar</span>
                <h2 class="mb-4">Danışmanlarımız</h2>
            </div>
        </div>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 ftco-animate">
                    <div class="agent">
                        <div class="img">
                            <img src="@item.EmployeeImageUrl" class="img-fluid" alt="Colorlib Template">
                        </div>
                        <div class="desc">
                            <h3><a href="properties.html">@item.EmployeeNameSurname</a></h3>
                            <p class="h-info"><span class="location">Portföy</span> <span class="details">&mdash; @item.TotalProductCount</span></p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
