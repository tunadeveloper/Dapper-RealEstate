@model List<RealEstate.WebUILayer.DTOs.ServiceDTOs.ResultServiceDTO>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@await Component.InvokeAsync("_PageHeroComponentPartial", new { title = "Hizmetler", breadcrumbCurrent = "Hizmetler" })

<section class="ftco-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-12 heading-section text-center ftco-animate mb-5">
                <span class="subheading">Hizmetlerimiz</span>
                <h2 class="mb-2">Size nasıl yardımcı oluyoruz</h2>
            </div>
        </div>
        <div class="row d-flex">
            @foreach (var item in Model)
            {
                <div class="col-md-4 d-flex align-self-stretch ftco-animate mb-4">
                    <div class="media block-6 services d-block text-center w-100">
                        <div class="icon d-flex justify-content-center align-items-center">
                            @if (!string.IsNullOrWhiteSpace(item.ServiceIcon))
                            {
                                <span class="@item.ServiceIcon"></span>
                            }
                            else
                            {
                                <span class="flaticon-piggy-bank"></span>
                            }
                        </div>
                        <div class="media-body py-md-4">
                            <p>@item.ServiceDescription</p>
                        </div>
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Henüz hizmet kaydı bulunmuyor.</p>
                </div>
            }
        </div>
    </div>
</section>
