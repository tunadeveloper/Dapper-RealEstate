@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>SignalR Durum Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
</head>
<body>

    <div class="content mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6 offset-md-3 mb-3">
                    <div id="connCard" class="alert alert-warning text-center">
                        Bağlantı Durumu: <strong id="connstatus">Bekleniyor...</strong>
                    </div>
                </div>

                <div class="col-md-6 offset-md-3">
                    <div class="card text-white bg-dark">
                        <div class="card-body text-center">
                            <h5 class="card-title">Toplam Kategori Sayısı</h5>
                            <h2 class="display-4" id="categoryCountDisplay">0</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script type="text/javascript">
        $(document).ready(() => {

            var connection = new signalR.HubConnectionBuilder()
                .withUrl("https://localhost:7175/SignalRHub")
                .withAutomaticReconnect()
                .build();
            connection.on("ReceiverCategoryCount", (value) => {
                $("#categoryCountDisplay").text(value);
            });
            function start() {
                connection.start()
                    .then(() => {
                        console.log("SignalR Bağlantısı Kuruldu.");
                        $("#connstatus").text("Bağlantı Sağlandı");
                        $("#connCard").removeClass("alert-warning alert-danger").addClass("alert-success");
                        connection.invoke("SendCategoryCount");
                    })
                    .catch((err) => {
                        console.error("Bağlantı Hatası: ", err);
                        $("#connstatus").text("Bağlantı Hatası!");
                        $("#connCard").removeClass("alert-warning alert-success").addClass("alert-danger");
                        setTimeout(start, 5000);
                    });
            }

            start();

        });
    </script>

</body>
</html>