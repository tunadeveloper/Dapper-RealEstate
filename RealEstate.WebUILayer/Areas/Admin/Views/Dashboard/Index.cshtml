@model RealEstate.WebUILayer.Areas.Admin.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/_AdminLayout.cshtml";
}

<main class="h-full overflow-y-auto">
    <div class="container px-6 mx-auto grid">
        <h2 class="my-6 text-2xl font-semibold text-gray-700 dark:text-gray-200">
            Özet istatistikler
        </h2>

        <div class="grid gap-6 mb-8 md:grid-cols-2 xl:grid-cols-4">
            <div class="flex items-center p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <div class="p-3 mr-4 text-purple-600 bg-purple-100 rounded-full dark:text-purple-100 dark:bg-purple-600">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
                </div>
                <div>
                    <p class="mb-2 text-sm font-medium text-gray-600 dark:text-gray-400">Toplam ilan</p>
                    <p class="text-lg font-semibold text-gray-700 dark:text-gray-200">@Model.ProductCount</p>
                </div>
            </div>
            <div class="flex items-center p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <div class="p-3 mr-4 text-green-500 bg-green-100 rounded-full dark:text-green-100 dark:bg-green-500">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd"></path></svg>
                </div>
                <div>
                    <p class="mb-2 text-sm font-medium text-gray-600 dark:text-gray-400">Aboneler</p>
                    <p class="text-lg font-semibold text-gray-700 dark:text-gray-200">@Model.SubscriberCount</p>
                </div>
            </div>
            <div class="flex items-center p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <div class="p-3 mr-4 text-indigo-500 bg-indigo-100 rounded-full dark:text-indigo-100 dark:bg-indigo-500">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 5a2 2 0 012-2h7a2 2 0 012 2v4a2 2 0 01-2 2H9l-3 3v-3H4a2 2 0 01-2-2V5z"></path><path d="M15 7v2a4 4 0 01-4 4H9.828l-1.766 1.767c.28.149.599.233.938.233h2l3 3v-3h2a2 2 0 002-2V9a2 2 0 00-2-2h-1z"></path></svg>
                </div>
                <div>
                    <p class="mb-2 text-sm font-medium text-gray-600 dark:text-gray-400">Mesajlar</p>
                    <p class="text-lg font-semibold text-gray-700 dark:text-gray-200">@Model.MessageCount</p>
                </div>
            </div>
            <div class="flex items-center p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <div class="p-3 mr-4 text-orange-500 bg-orange-100 rounded-full dark:text-orange-100 dark:bg-orange-500">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </div>
                <div>
                    <p class="mb-2 text-sm font-medium text-gray-600 dark:text-gray-400">Kategoriler</p>
                    <p class="text-lg font-semibold text-gray-700 dark:text-gray-200">@Model.CategoryCount</p>
                </div>
            </div>
        </div>

        <div class="grid gap-6 mb-8 md:grid-cols-2">
            <div class="min-w-0 p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <h3 class="mb-1 font-semibold text-gray-800 dark:text-gray-200">İlanlar ve fiyatlar</h3>
                <p class="mb-4 text-xs text-gray-500 dark:text-gray-400">İlan başlıklarına göre fiyatlar (yüksek fiyata göre, en fazla 15 ilan)</p>
                <div class="relative" style="height: 320px;">
                    <canvas id="chartEntities"></canvas>
                </div>
                @if (Model.ProductsPriceChart.Count == 0)
                {
                    <p class="mt-2 text-sm text-center text-gray-500 dark:text-gray-400">Gösterilecek ilan yok.</p>
                }
            </div>
            <div class="min-w-0 p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <h3 class="mb-1 font-semibold text-gray-800 dark:text-gray-200">Popüler ilan fiyatları</h3>
                <p class="mb-4 text-xs text-gray-500 dark:text-gray-400">Popüler işaretli ilanların başlıklarına göre fiyat karşılaştırması</p>
                <div class="relative" style="height: 320px;">
                    <canvas id="chartCategories"></canvas>
                </div>
                @if (Model.PopularProductsPriceChart.Count == 0)
                {
                    <p class="mt-2 text-sm text-center text-gray-500 dark:text-gray-400">Popüler ilan bulunamadı.</p>
                }
            </div>
        </div>

        <div class="grid gap-6 mb-8 md:grid-cols-2">
            <div class="p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <h3 class="mb-3 text-sm font-semibold text-gray-700 dark:text-gray-200">Fiyat (₺)</h3>
                <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                    <li class="flex justify-between"><span>Ortalama</span><span class="font-semibold text-gray-800 dark:text-gray-200">@Model.AverageProductPrice.ToString("N2")</span></li>
                    <li class="flex justify-between"><span>En yüksek</span><span class="font-semibold text-gray-800 dark:text-gray-200">@Model.MaxProductPrice.ToString("N2")</span></li>
                    <li class="flex justify-between"><span>En düşük</span><span class="font-semibold text-gray-800 dark:text-gray-200">@Model.MinProductPrice.ToString("N2")</span></li>
                </ul>
            </div>
            <div class="p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <h3 class="mb-3 text-sm font-semibold text-gray-700 dark:text-gray-200">Öne çıkanlar</h3>
                <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
                    <li><span class="text-gray-500 dark:text-gray-500">En çok ilanın olduğu kategori:</span><br /><span class="font-medium text-gray-800 dark:text-gray-200">@(Model.CategoryNameByMaxProductCount ?? "—")</span></li>
                    <li><span class="text-gray-500 dark:text-gray-500">En çok ilanın olduğu şehir:</span><br /><span class="font-medium text-gray-800 dark:text-gray-200">@(Model.CityNameByMaxProductCount ?? "—")</span></li>
                    <li><span class="text-gray-500 dark:text-gray-500">En çok ilanı olan çalışan:</span><br /><span class="font-medium text-gray-800 dark:text-gray-200">@(Model.EmployeeNameByMaxProductCount ?? "—")</span></li>
                </ul>
            </div>
        </div>
    </div>
</main>

<script>
    window.addEventListener('load', function () {
        if (typeof Chart === 'undefined') return;

        var gridColor = document.documentElement.classList.contains('theme-dark') ? 'rgba(226,232,240,0.15)' : 'rgba(0,0,0,0.06)';
        var tickColor = document.documentElement.classList.contains('theme-dark') ? '#e2e8f0' : '#4a5568';

        var labels1 = @Html.Raw(Model.Chart1LabelsJson);
        var data1 = @Html.Raw(Model.Chart1PricesJson);
        var labels2 = @Html.Raw(Model.Chart2LabelsJson);
        var data2 = @Html.Raw(Model.Chart2PricesJson);

        var ctxBar = document.getElementById('chartEntities');
        if (ctxBar && labels1.length > 0) {
            new Chart(ctxBar.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labels1,
                    datasets: [{
                        label: 'Fiyat (₺)',
                        data: data1,
                        backgroundColor: 'rgba(124, 58, 237, 0.75)',
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    legend: { display: true, labels: { fontColor: tickColor } },
                    scales: {
                        xAxes: [{
                            ticks: { fontColor: tickColor, maxRotation: 60, minRotation: 45, autoSkip: true, maxTicksLimit: 20 },
                            gridLines: { color: gridColor }
                        }],
                        yAxes: [{
                            ticks: { beginAtZero: true, fontColor: tickColor },
                            gridLines: { color: gridColor }
                        }]
                    }
                }
            });
        }

        var ctxPop = document.getElementById('chartCategories');
        if (ctxPop && labels2.length > 0) {
            var popPalette = [
                'rgba(124, 58, 237, 0.8)', 'rgba(249, 115, 22, 0.8)', 'rgba(34, 197, 94, 0.8)',
                'rgba(59, 130, 246, 0.8)', 'rgba(236, 72, 153, 0.8)', 'rgba(234, 179, 8, 0.8)',
                'rgba(20, 184, 166, 0.8)', 'rgba(99, 102, 241, 0.8)', 'rgba(168, 85, 247, 0.8)', 'rgba(239, 68, 68, 0.8)'
            ];
            var popColors = labels2.map(function (_, i) { return popPalette[i % popPalette.length]; });
            new Chart(ctxPop.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labels2,
                    datasets: [{
                        label: 'Fiyat (₺)',
                        data: data2,
                        backgroundColor: popColors,
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    legend: { display: false },
                    scales: {
                        xAxes: [{
                            ticks: { fontColor: tickColor, maxRotation: 45, minRotation: 0 },
                            gridLines: { color: gridColor }
                        }],
                        yAxes: [{
                            ticks: { beginAtZero: true, fontColor: tickColor },
                            gridLines: { color: gridColor }
                        }]
                    }
                }
            });
        }
    });
</script>
