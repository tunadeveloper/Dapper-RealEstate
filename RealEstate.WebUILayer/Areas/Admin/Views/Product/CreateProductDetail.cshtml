@using RealEstate.WebUILayer.DTOs.ProductDetailDTOs
@model CreateProductDetailDTO
@{
    ViewData["Title"] = "CreateProductDetail";
    Layout = "~/Areas/Admin/Views/_AdminLayout.cshtml";
}

<main class="h-full pb-16 overflow-y-auto">
    <div class="container px-6 mx-auto grid">
        <h2 class="my-6 text-2xl font-semibold text-gray-700 dark:text-gray-200">
            İlan Detayı Ekle
        </h2>

        <form method="post" action="/Admin/Product/CreateProductDetail">

            <div class="px-4 py-3 mb-8 bg-white rounded-lg shadow-md dark:bg-gray-800">

                <label class="block text-sm">
                    <span class="text-gray-700 dark:text-gray-400">İlan ID (Zorunlu)</span>
                    <input type="number"
                           name="ProductId"
                           value="@ViewBag.productId"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="İlan ID giriniz..."
                           required readonly />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Ürün Boyutu (m²)</span>
                    <input type="number"
                           name="ProductSize"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Büyüklük giriniz..."
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Yatak Odası Sayısı</span>
                    <input type="number"
                           name="ProductBedRoomCount"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Örn: 3"
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Banyo Sayısı</span>
                    <input type="number"
                           name="ProductBathCount"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Örn: 2"
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Oda Sayısı</span>
                    <input type="number"
                           name="ProductRoomCount"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Örn: 4"
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Garaj Büyüklüğü (Araç Sayısı)</span>
                    <input type="number"
                           name="ProductGarageSize"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Örn: 1"
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Yapım Yılı</span>
                    <input type="text"
                           name="ProductBuildYear"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Örn: 2023"
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Fiyat</span>
                    <input type="number" step="0.01"
                           name="ProductPrice"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Fiyat..."
                           required />
                </label>

                <label class="block mt-4 text-sm">
                    <span class="text-gray-700 dark:text-gray-400">Lokasyon URL (Harita İframe vb.)</span>
                    <input type="text"
                           name="ProductLocation"
                           class="block w-full mt-1 text-sm dark:border-gray-600 dark:bg-gray-700 focus:border-purple-400 focus:outline-none focus:shadow-outline-purple dark:text-gray-300 dark:focus:shadow-outline-gray form-input rounded-md border-gray-300 shadow-sm"
                           placeholder="Lokasyon veya iframe URL..."
                           required />
                </label>

                <div class="mt-6">
                    <button type="submit"
                            class="px-4 py-2 text-sm font-medium leading-5 text-white transition-colors duration-150 bg-purple-600 border border-transparent rounded-lg active:bg-purple-600 hover:bg-purple-700 focus:outline-none focus:shadow-outline-purple">
                        Detay Ekle
                    </button>
                    <a href="/Admin/Product/Index"
                       class="ml-2 px-4 py-2 text-sm font-medium leading-5 text-gray-700 transition-colors duration-150 border border-gray-300 rounded-lg hover:bg-gray-100 focus:outline-none focus:shadow-outline-gray dark:text-gray-400 dark:border-gray-600 dark:hover:bg-gray-700 dark:hover:text-gray-300">
                        İptal
                    </a>
                </div>

            </div>
        </form>

    </div>
</main>
