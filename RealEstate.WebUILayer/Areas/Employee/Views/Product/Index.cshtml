@using X.PagedList
@using X.PagedList.Mvc.Core
@using RealEstate.WebUILayer.DTOs.ProductDTOs
@model IPagedList<ResultProductDTO>
@{
    ViewData["Title"] = "İlanlarım";
    Layout = "~/Areas/Employee/Views/_EmployeeLayout.cshtml";
}

<main class="h-full overflow-y-auto">
    <div class="container px-6 mx-auto">
        <div class="flex justify-between items-center my-8">
            <h2 class="text-3xl font-bold text-gray-700 dark:text-gray-200">
                İlanlarım
            </h2>
            <a href="/Employee/Product/CreateProduct" class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors duration-150 focus:outline-none focus:shadow-outline-purple">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg>
                Yeni İlan Ekle
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="px-4 py-3 mb-6 bg-green-100 border border-green-400 text-green-700 rounded-lg shadow-sm flex items-center" role="alert">
                <svg class="w-5 h-5 mr-3 fill-current flex-shrink-0" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                <span class="font-semibold">@TempData["Success"]</span>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="px-4 py-3 mb-6 bg-red-100 border border-red-400 text-red-700 rounded-lg shadow-sm flex items-center" role="alert">
                <svg class="w-5 h-5 mr-3 fill-current flex-shrink-0" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                </svg>
                <span class="font-semibold">@TempData["Error"]</span>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="mb-6">
                @foreach (var item in Model)
                {
                    <div class="bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700 overflow-hidden flex flex-col">
                        <div class="relative h-48 bg-gray-200 dark:bg-gray-700">
                            <img class="w-full h-full object-cover"
                                 src="@item.ProductCoverImage"
                                 alt="@item.ProductTitle"
                                 loading="lazy"
                                 onerror="this.src='https://via.placeholder.com/400x200?text=Görsel+Yok'" />
                        </div>

                        <div class="p-5 flex flex-col flex-1">
                            <div style="display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.5rem;">
                                <span style="flex-shrink: 0; margin-top: 0.125rem;">
                                    @if (item.ProductIsPopular)
                                    {
                                        <span class="inline-block px-2 py-1 text-xs font-bold text-green-700 bg-green-100 rounded-full dark:bg-green-700 dark:text-green-100 shadow">
                                            Popüler
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-block px-2 py-1 text-xs font-bold text-gray-600 bg-gray-100 rounded-full dark:bg-gray-600 dark:text-gray-200 shadow">
                                            Normal
                                        </span>
                                    }
                                </span>
                                <h3 class="text-base font-semibold text-gray-800 dark:text-gray-100 leading-snug" style="flex: 1; min-width: 0; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @item.ProductTitle
                                </h3>
                            </div>

                            <div class="flex items-center mb-1 text-sm text-gray-500 dark:text-gray-400">
                                <svg class="w-4 h-4 mr-1 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                @item.ProductCity - @item.ProductDistrict
                            </div>

                            <div class="mb-4 text-xl font-bold text-purple-600 dark:text-purple-400">
                                ₺@item.ProductPrice.ToString("N2")
                            </div>

                            <div class="mt-auto flex flex-wrap gap-2">
                                <a href="/Employee/Product/UpdateProduct/@item.ProductId"
                                   class="flex-1 text-center px-3 py-2 text-xs font-semibold text-white bg-purple-600 rounded-lg hover:bg-purple-700 transition-colors duration-150 focus:outline-none">
                                    Güncelle
                                </a>
                                <a href="/Employee/Product/ProductDetail/@item.ProductId"
                                   class="flex-1 text-center px-3 py-2 text-xs font-semibold text-white rounded-lg transition-colors duration-150 focus:outline-none"
                                   style="background-color: #f97316;">
                                    Detaylar
                                </a>
                                <a href="/Employee/Product/DeleteProduct/@item.ProductId"
                                   onclick="return confirm('Bu ilanı silmek istediğinize emin misiniz?')"
                                   class="flex-1 text-center px-3 py-2 text-xs font-semibold text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors duration-150 focus:outline-none">
                                    Sil
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="flex items-center justify-between px-4 py-3 mb-8 bg-white rounded-lg shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700 text-sm text-gray-600 dark:text-gray-400">
                <span>
                    Sayfa <strong>@Model.PageNumber</strong> / <strong>@Model.PageCount</strong> &nbsp;·&nbsp; Toplam <strong>@Model.TotalItemCount</strong> ilan
                </span>
                <span>
                    @Html.PagedListPager(Model, page => Url.Action(nameof(Index), new { page }), new PagedListRenderOptions
                    {
                        UlElementClasses = new[] { "inline-flex", "items-center", "space-x-1" },
                        LiElementClasses = new[] { "px-3", "py-1", "rounded-md", "focus:outline-none", "focus:shadow-outline-purple" },
                        ActiveLiElementClass = "text-white bg-purple-600 rounded-md"
                    })
                </span>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <svg class="w-16 h-16 mb-4 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
                <p class="text-lg font-semibold text-gray-500 dark:text-gray-400">Henüz hiç ilanınız yok</p>
                <p class="mt-1 text-sm text-gray-400 dark:text-gray-500">Yeni bir ilan ekleyerek başlayabilirsiniz.</p>
                <a href="/Employee/Product/CreateProduct" class="mt-6 inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-purple-600 rounded-lg hover:bg-purple-700">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"></path></svg>
                    İlk İlanı Ekle
                </a>
            </div>
        }

    </div>
</main>
