@using RealEstate.WebUILayer.DTOs.EmployeeDTOs
@model ResultEmployeeDTO?
@{
    Layout = "~/Areas/Employee/Views/_EmployeeLayout.cshtml";
}

<main class="h-full overflow-y-auto">
    <div class="container px-6 mx-auto grid">
        <h2 class="my-6 text-2xl font-semibold text-gray-700 dark:text-gray-200">
            Ana sayfa
        </h2>

        <div class="grid gap-6 mb-8 md:grid-cols-3">
            <a href="/Employee/Product/Index" class="block p-6 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">İlanlarım</p>
                <p class="mt-2 text-lg font-semibold text-gray-700 dark:text-gray-200">Listeyi aç</p>
            </a>
            <a href="/Employee/Product/CreateProduct" class="block p-6 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Yeni ilan</p>
                <p class="mt-2 text-lg font-semibold text-gray-700 dark:text-gray-200">İlan oluştur</p>
            </a>
            <a href="/Employee/Message/Index" class="block p-6 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Mesajlar</p>
                <p class="mt-2 text-lg font-semibold text-gray-700 dark:text-gray-200">Gelen kutusu</p>
            </a>
        </div>

        @if (Model is null)
        {
            <div class="p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <p class="text-gray-700 dark:text-gray-200">Profil bilgisi bulunamadı.</p>
            </div>
        }
        else
        {
            <div class="p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
                <div class="flex items-center">
                    <img class="w-20 h-20 rounded-full object-cover" src="@Model.EmployeeImageUrl" alt="@Model.EmployeeNameSurname" />
                    <div class="ml-4">
                        <p class="text-lg font-semibold text-gray-700 dark:text-gray-200">@Model.EmployeeNameSurname</p>
                        <p class="text-sm text-gray-600 dark:text-gray-400">@Model.EmployeeTitle</p>
                    </div>
                </div>
                <div class="mt-4">
                    <p class="text-sm text-gray-700 dark:text-gray-200">E-posta: @Model.EmployeeEmail</p>
                    <p class="text-sm text-gray-700 dark:text-gray-200">Telefon: @Model.EmployeePhoneNumber</p>
                </div>
            </div>
        }
    </div>
</main>
