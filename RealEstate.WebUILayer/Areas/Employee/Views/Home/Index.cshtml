@model RealEstate.WebUILayer.Areas.Employee.Models.EmployeeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Employee/Views/_EmployeeLayout.cshtml";
}

<main class="h-full overflow-y-auto">
    <div class="container px-6 mx-auto">

        <h2 class="my-8 text-3xl font-bold text-gray-700 dark:text-gray-200">
            Hoş geldiniz, <span class="text-purple-600">@Model.EmployeeName</span>
        </h2>
        <p class="mb-8 text-sm text-gray-500 dark:text-gray-400 -mt-4">İşte sistemdeki güncel istatistikler</p>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="mb-8">

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-purple-600 bg-purple-100 rounded-xl dark:text-purple-100 dark:bg-purple-600 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Sistemdeki Toplam İlan</p>
                    <p class="text-4xl font-bold text-gray-700 dark:text-gray-200">@Model.TotalProductCount</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-green-600 bg-green-100 rounded-xl dark:text-green-100 dark:bg-green-600 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Benim İlanlarım</p>
                    <p class="text-4xl font-bold text-purple-600">@Model.MyProductCount</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-indigo-600 bg-indigo-100 rounded-xl dark:text-indigo-100 dark:bg-indigo-600 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Toplam Kategori</p>
                    <p class="text-4xl font-bold text-gray-700 dark:text-gray-200">@Model.CategoryCount</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-orange-500 bg-orange-100 rounded-xl dark:text-orange-100 dark:bg-orange-500 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Farklı Şehir</p>
                    <p class="text-4xl font-bold text-gray-700 dark:text-gray-200">@Model.DifferentCityCount</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-pink-600 bg-pink-100 rounded-xl dark:text-pink-100 dark:bg-pink-600 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Farklı İlçe</p>
                    <p class="text-4xl font-bold text-gray-700 dark:text-gray-200">@Model.DifferentDistrictCount</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-teal-600 bg-teal-100 rounded-xl dark:text-teal-100 dark:bg-teal-600 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Daire İlanı Sayısı</p>
                    <p class="text-4xl font-bold text-gray-700 dark:text-gray-200">@Model.ApartmentCount</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-yellow-600 bg-yellow-100 rounded-xl dark:text-yellow-100 dark:bg-yellow-600 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path>
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">Ortalama Fiyat</p>
                    <p class="text-3xl font-bold text-gray-700 dark:text-gray-200">₺@Model.AverageProductPrice.ToString("N0")</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-red-500 bg-red-100 rounded-xl dark:text-red-100 dark:bg-red-500 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">En Yüksek Fiyat</p>
                    <p class="text-3xl font-bold text-gray-700 dark:text-gray-200">₺@Model.MaxProductPrice.ToString("N0")</p>
                </div>
            </div>

            <div class="flex items-center p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <div class="p-4 mr-5 text-blue-500 bg-blue-100 rounded-xl dark:text-blue-100 dark:bg-blue-500 flex-shrink-0">
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M12 13a1 1 0 100 2h5a1 1 0 001-1V9a1 1 0 10-2 0v2.586l-4.293-4.293a1 1 0 00-1.414 0L8 9.586 3.707 5.293a1 1 0 00-1.414 1.414l5 5a1 1 0 001.414 0L11 9.414 14.586 13H12z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div>
                    <p class="mb-1 text-sm font-medium text-gray-500 dark:text-gray-400">En Düşük Fiyat</p>
                    <p class="text-3xl font-bold text-gray-700 dark:text-gray-200">₺@Model.MinProductPrice.ToString("N0")</p>
                </div>
            </div>

        </div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;" class="mb-10">
            <div class="p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <h3 class="mb-4 text-base font-semibold text-gray-700 dark:text-gray-200">Fiyat Özeti</h3>
                <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
                    <li class="flex justify-between items-center border-b pb-3 dark:border-gray-700">
                        <span>Ortalama fiyat</span>
                        <span class="font-semibold text-gray-800 dark:text-gray-200">₺@Model.AverageProductPrice.ToString("N2")</span>
                    </li>
                    <li class="flex justify-between items-center border-b pb-3 dark:border-gray-700">
                        <span>En yüksek fiyat</span>
                        <span class="font-semibold text-gray-800 dark:text-gray-200">₺@Model.MaxProductPrice.ToString("N2")</span>
                    </li>
                    <li class="flex justify-between items-center">
                        <span>En düşük fiyat</span>
                        <span class="font-semibold text-gray-800 dark:text-gray-200">₺@Model.MinProductPrice.ToString("N2")</span>
                    </li>
                </ul>
            </div>

            <div class="p-6 bg-white rounded-xl shadow-sm dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
                <h3 class="mb-4 text-base font-semibold text-gray-700 dark:text-gray-200">İlan Durumum</h3>
                <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
                    <li class="flex justify-between items-center border-b pb-3 dark:border-gray-700">
                        <span>Sistemdeki toplam ilan</span>
                        <span class="font-semibold text-gray-800 dark:text-gray-200">@Model.TotalProductCount</span>
                    </li>
                    <li class="flex justify-between items-center border-b pb-3 dark:border-gray-700">
                        <span>Benim ilanlarım</span>
                        <span class="font-semibold text-purple-600">@Model.MyProductCount</span>
                    </li>
                    <li class="flex justify-between items-center">
                        <span>Diğer çalışanların ilanları</span>
                        <span class="font-semibold text-gray-800 dark:text-gray-200">@(Model.TotalProductCount - Model.MyProductCount)</span>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</main>
