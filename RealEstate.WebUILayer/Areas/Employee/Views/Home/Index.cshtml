@using RealEstate.WebUILayer.DTOs.EmployeeDTOs
@model ResultEmployeeDTO
@{
    Layout = "~/Areas/Admin/Views/_AdminLayout.cshtml";
}

<div class="container px-6 mx-auto grid">
    <h2 class="my-6 text-2xl font-semibold text-gray-700 dark:text-gray-200">
        Employee Paneli
    </h2>

    @if (Model is null)
    {
        <div class="p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
            <p class="text-gray-700 dark:text-gray-200">Profil bilgisi bulunamadı.</p>
        </div>
    }
    else
    {
        <div class="p-4 bg-white rounded-lg shadow-xs dark:bg-gray-800">
            <div class="flex items-center">
                <img class="w-20 h-20 rounded-full object-cover" src="@Model.EmployeeImageUrl" alt="@Model.EmployeeNameSurname" />
                <div class="ml-4">
                    <p class="text-lg font-semibold text-gray-700 dark:text-gray-200">@Model.EmployeeNameSurname</p>
                    <p class="text-sm text-gray-600 dark:text-gray-400">@Model.EmployeeTitle</p>
                </div>
            </div>
            <div class="mt-4">
                <p class="text-sm text-gray-700 dark:text-gray-200">E-posta: @Model.EmployeeEmail</p>
                <p class="text-sm text-gray-700 dark:text-gray-200">Telefon: @Model.EmployeePhoneNumber</p>
            </div>
        </div>
    }
</div>
